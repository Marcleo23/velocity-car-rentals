{
  "entities": {
    "Car": {
      "title": "Car",
      "description": "A vehicle available for rent",
      "type": "object",
      "properties": {
        "make": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "integer" },
        "category": { "type": "string" },
        "pricePerDay": { "type": "number" },
        "transmission": { "type": "string", "enum": ["Automatic", "Manual"] },
        "fuelType": { "type": "string", "enum": ["Petrol", "Diesel", "Electric", "Hybrid"] },
        "seats": { "type": "integer" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "rented", "maintenance"] },
        "description": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["make", "model", "year", "category", "pricePerDay", "status"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A car rental reservation",
      "type": "object",
      "properties": {
        "carId": { "type": "string" },
        "userId": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["carId", "userId", "startDate", "endDate", "totalPrice", "status"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account information and roles",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "phoneNumber": { "type": "string" }
      },
      "required": ["email", "displayName", "role"]
    }
  },
  "firestore": {
    "/cars/{carId}": {
      "schema": "Car",
      "description": "Collection of available vehicles"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of rental reservations"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and roles"
    }
  }
}
